{
  "name": "@yanfishel/codeframe",
  "version": "0.1.0",
  "private": true,
  "description": "Code Frame - built with Next.js, TypeScript, Mantine, and Storybook",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanfishel/code-frame.git"
  },
  "bugs": {
    "url": "https://github.com/yanfishel/code-frame/issues"
  },
  "author": {
    "name": "Yan Fishel",
    "email": "yan.fishel@gmail.com"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "export": "next build && next export",
    "typecheck": "tsc --noEmit",
    "lint": "npm run eslint && npm run stylelint",
    "eslint": "eslint .",
    "stylelint": "stylelint '**/*.css' --cache",
    "prettier:check": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@mantine/core": "8.3.17",
    "@mantine/hooks": "8.3.17",
    "@next/bundle-analyzer": "^16.0.0",
    "@tabler/icons-react": "^3.35.0",
    "lucide-react": "^1.7.0",
    "next": "16.1.7",
    "prismjs": "^1.30.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-draggable": "^4.5.0",
    "react-simple-code-editor": "^0.14.1",
    "use-sync-external-store": "^1.6.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^9.37.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@types/eslint-plugin-jsx-a11y": "^6",
    "@types/node": "^25.0.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.1",
    "@types/use-sync-external-store": "^1",
    "babel-loader": "^10.0.0",
    "eslint": "^9.37.0",
    "eslint-config-mantine": "^4.0.3",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.5.6",
    "postcss-preset-mantine": "1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.6.2",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.46.0"
